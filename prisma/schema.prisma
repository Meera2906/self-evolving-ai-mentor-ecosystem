datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

generator client {
  provider = "prisma-client-js"
}

model Student {
  id         String             @id @default(uuid())
  name       String             @unique
  attempts   Attempt[]
  progress   TopicProgress[]
  quizzes    Quiz[]
  onboarding OnboardingProfile? @relation("StudentOnboarding")
  plans      LearningPlan[]
  concepts   ConceptProgress[]
}

model Attempt {
  id        String   @id @default(uuid())
  studentId String
  topic     String
  score     Int
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId, topic])
}

model TopicProgress {
  id        String   @id @default(uuid())
  studentId String
  topic     String
  mastery   String
  attempts  Int
  avgScore  Float
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, topic])
}

model Quiz {
  id         String   @id @default(uuid())
  studentId  String
  topic      String
  difficulty String
  createdAt  DateTime @default(now())

  student   Student    @relation(fields: [studentId], references: [id])
  questions Question[]

  @@index([studentId, topic])
}

model Question {
  id           String   @id @default(uuid())
  quizId       String
  question     String
  options      String[]
  correctIndex Int
  explanation  String
  concept      String?

  quiz    Quiz            @relation(fields: [quizId], references: [id])
  answers StudentAnswer[]
}

model StudentAnswer {
  id            String  @id @default(uuid())
  questionId    String
  selectedIndex Int
  isCorrect     Boolean

  question Question @relation(fields: [questionId], references: [id])
}

model OnboardingProfile {
  id        String @id @default(uuid())
  studentId String @unique
  data      Json

  student Student @relation("StudentOnboarding", fields: [studentId], references: [id])
}

model LearningPlan {
  id        String   @id @default(uuid())
  studentId String
  topic     String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, topic])
}

model ConceptProgress {
  id        String @id @default(uuid())
  studentId String
  topic     String
  concept   String
  attempts  Int
  correct   Int
  accuracy  Float

  student Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, topic, concept])
}
