datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Student {
  id                String            @id @default(uuid())
  name              String            @unique
  onboardingProfile Json?

  attempts          Attempt[]
  progress          TopicProgress[]
  quizzes           Quiz[]
  learningPlans     LearningPlan[]
  conceptProgress   ConceptProgress[]
}

model Attempt {
  id        String   @id @default(uuid())
  studentId String
  topic     String
  score     Int
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId, topic])
}

model TopicProgress {
  id        String   @id @default(uuid())
  studentId String
  topic     String
  mastery   String
  attempts  Int
  avgScore  Float
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, topic])
}

model ConceptProgress {
  id        String   @id @default(uuid())
  studentId String
  topic     String
  concept   String
  attempts  Int
  correct   Int
  accuracy  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, topic, concept])
}

model LearningPlan {
  id        String   @id @default(uuid())
  studentId String
  topic     String
  planJson  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, topic])
}

model Quiz {
  id         String     @id @default(uuid())
  studentId  String
  topic      String
  difficulty String
  createdAt  DateTime   @default(now())

  student   Student    @relation(fields: [studentId], references: [id])
  questions Question[]
  
}

model Question {
  id           String          @id @default(uuid())
  quizId        String
  question      String
  options       String[]
  correctIndex  Int
  explanation   String
  concept       String?

  quiz     Quiz            @relation(fields: [quizId], references: [id])
  answers  StudentAnswer[]
}

model StudentAnswer {
  id            String   @id @default(uuid())
  questionId    String
  selectedIndex Int
  isCorrect     Boolean

  question Question @relation(fields: [questionId], references: [id])
}
